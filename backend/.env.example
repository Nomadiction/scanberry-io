# ============================================================
# ScanBerry.io Backend — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# For Azure deployment, set these in App Service > Configuration.
# ============================================================

# --- Application ---
APP_ENV=development                    # development | production
LOG_LEVEL=INFO                         # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-to-random-string  # used for future auth tokens

# --- Database ---
# Local development (SQLite):
DATABASE_URL=sqlite+aiosqlite:///./storage/scanberry.db
# Azure PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/scanberry

# --- Storage ---
STORAGE_BACKEND=local                  # local | azure
LOCAL_STORAGE_PATH=./storage           # path for local file storage

# Azure Blob Storage (only when STORAGE_BACKEND=azure):
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=scanberry-images

# --- ML Models ---
# Paths to trained model weights (relative to backend/ or absolute)
MODEL_DETECTION_PATH=../models/detection/best_model_Yolo.pt
MODEL_CLASSIFICATION_PATH=../models/classification/best_model_EfficientNet.pt
MODEL_SEGMENTATION_PATH=                # legacy, unused
MODEL_SEGMENTATION_BUSH_PATH=../models/segmentation/best_model_U-Net.pth
MODEL_SEGMENTATION_LESION_PATH=../models/segmentation/best_model_DeepLab.pth

# Inference device: cpu | cuda | cuda:0
DEVICE=cpu

# --- API ---
API_V1_PREFIX=/api/v1
# Explicit CORS origins (JSON array). Add the deployed frontend URL here.
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://localhost:8080","https://scanberry.io"]
# Optional regex for dynamic origins (e.g. Azure Static Web Apps preview slots).
# Example below matches every *.azurestaticapps.net subdomain (production + PR previews).
CORS_ORIGIN_REGEX=https://.*\.azurestaticapps\.net
MAX_UPLOAD_SIZE_MB=20
