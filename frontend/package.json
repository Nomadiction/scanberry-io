{
  "name": "scanberry-frontend",
  "private": true,
  "version": "2.6.7",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "deploy:stage": "npm run build && swa deploy ./dist --app-name scanberry-web --no-use-keychain",
    "deploy:prod": "npm run build && swa deploy ./dist --app-name scanberry-web --no-use-keychain --env production",
    "deploy:stage:only": "swa deploy ./dist --app-name scanberry-web --no-use-keychain",
    "deploy:prod:only": "swa deploy ./dist --app-name scanberry-web --no-use-keychain --env production"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.96.2",
    "@twa-dev/sdk": "^8.0.2",
    "clsx": "2.1.1",
    "lucide-react": "0.487.0",
    "motion": "12.23.24",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router": "7.13.0",
    "tailwind-merge": "3.2.0",
    "tw-animate-css": "1.3.8"
  },
  "devDependencies": {
    "@azure/static-web-apps-cli": "^2.0.9",
    "@tailwindcss/vite": "4.1.12",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "4.7.0",
    "tailwindcss": "4.1.12",
    "typescript": "^5.6.0",
    "vite": "^6.4.2"
  }
}
