# ===== ScanBerry frontend — environment variables =====
# Copy to `.env` for local development.
# Production builds (Azure Static Web Apps) use `.env.production`.

# URL of the FastAPI backend (no trailing slash, no /api/v1 suffix).
# Local dev:        http://localhost:8000
# Azure App Service: https://scanberry-api.azurewebsites.net
VITE_API_BASE_URL=http://localhost:8000

# Set to "true" to bypass the network and use bundled mock data.
# Useful when working on UI without a running backend.
VITE_USE_MOCK=false
