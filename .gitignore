# ============================================================
# ScanBerry.io — repository .gitignore
# ============================================================
# Layout:
#   Section 1 — Heavyweight artefacts (NEVER commit)
#   Section 2 — Python (backend)
#   Section 3 — Node / frontend
#   Section 4 — Editors & OS
#   Section 5 — Tooling (Docker, Azure, Claude, env)
# ============================================================

# ─── 1. Heavyweight artefacts ─────────────────────────────────
# Trained model weights — distributed out-of-band (Azure Blob,
# release attachments, or rebuilt via notebooks in ml-research/).
models/
!models/.gitkeep

# Raw dataset and Label Studio exports — too large for git and
# may contain unredacted field photos. Kept locally only.
dataset/
!dataset/.gitkeep

# Backend file storage (uploads, generated overlays, SQLite db).
backend/storage/*
!backend/storage/.gitkeep
backend/storage/*.db
backend/storage/uploads/
backend/storage/results/

# ─── 2. Python (backend) ──────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.eggs/
build/
dist/
sdist/
wheels/
pip-wheel-metadata/

# Virtual envs
.venv/
venv/
env/
ENV/

# Test / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover

# Type checkers
.mypy_cache/
.pyre/
.pytype/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# ─── 3. Node / frontend ───────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.vite/
frontend/.swa/

# npm / yarn / pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Vite cache
.vite/

# ─── 4. Editors & OS ──────────────────────────────────────────
# JetBrains
.idea/
*.iml

# VS Code (keep shareable settings, ignore personal)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# Cursor
.cursor/

# OS junk
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/

# ─── 5. Tooling: Docker / Azure / Claude / env ────────────────
# Docker
docker-compose.override.yml

# Azure / SWA local secrets
.azure/
swa-cli.config.json
.swa-cli/

# Claude Code: per-user / per-machine settings only
.claude/settings.local.json
.claude/cache/
.claude/projects/

# Environment files (NEVER commit real secrets)
# Allowed: .env.example (template) and .env.production / .env.staging
# (Vite bakes public VITE_* values into the bundle at build time — they
# are not secrets). Everything else (.env, .env.local, ...) stays out.
.env
.env.*
!.env.example
!**/.env.example
!.env.production
!**/.env.production
!.env.staging
!**/.env.staging

# Local ad-hoc scratch
scratch/
tmp/
*.tmp
*.bak
*.swp
*~
